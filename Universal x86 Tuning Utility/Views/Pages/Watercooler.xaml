<Page x:Class="Universal_x86_Tuning_Utility.Views.Pages.Watercooler"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Watercooler Control"
    Unloaded="Page_Unloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">

            <!-- Header -->
            <TextBlock Text="LCT Watercooler Control"
                FontSize="20" FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Margin="0,0,0,16"/>

        <!-- Device Discovery Section -->
        <ui:CardControl x:Name="cardDiscovery" Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Bluetooth24" Margin="0,0,8,0"/>
                    <TextBlock Text="Device Discovery"/>
                </StackPanel>
            </ui:CardControl.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="cbxDevices" Grid.Column="1" Margin="8,0" MinWidth="200" SelectionChanged="cbxDevices_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text=" (" Margin="6,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{Binding Address}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text=")" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="  RSSI: " Margin="12,0,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{Binding Rssi}" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button x:Name="btnScan" Grid.Column="2" Content="Scan for Devices" Width="160" Click="btnScan_Click"/>
            </Grid>
        </ui:CardControl>

        <!-- Connection Status -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Status24" Margin="0,0,8,0"/>
                    <TextBlock Text="Connection Status"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon x:Name="iconConnected" Symbol="Checkmark24" Visibility="Collapsed">
                    <ui:SymbolIcon.Foreground>
                        <SolidColorBrush Color="#00CC00"/>
                    </ui:SymbolIcon.Foreground>
                </ui:SymbolIcon>
                <ui:SymbolIcon x:Name="iconDisconnected" Symbol="EqualCircle24" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Visibility="Visible"/>
                <TextBlock x:Name="txtConnectionStatus" Text="Not connected" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <Button x:Name="btnConnect" Content="Connect" Width="100" Margin="12,0,0,0" Click="btnConnect_Click" IsEnabled="False"/>
                <Button x:Name="btnDisconnect" Content="Disconnect" Width="100" Margin="8,0,0,0" Click="btnDisconnect_Click" IsEnabled="False"/>
            </StackPanel>
        </ui:CardControl>

        <!-- Pump Control -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Play24" Margin="0,0,8,0"/>
                    <TextBlock Text="Pump Voltage"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel>
                <ComboBox x:Name="cbxPumpVoltage" MinWidth="160" SelectionChanged="cbxPumpVoltage_SelectionChanged">
                    <ComboBoxItem Content="Off"/>
                    <ComboBoxItem Content="7V"/>
                    <ComboBoxItem Content="8V"/>
                    <ComboBoxItem Content="11V"/>
                </ComboBox>
                <TextBlock Text="Select pump voltage level. Higher voltage = more cooling."
                    FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </ui:CardControl>

        <!-- Fan Control -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="RotateLeft24" Margin="0,0,8,0"/>
                    <TextBlock Text="Fan Speed"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel>
                <ComboBox x:Name="cbxFanSpeed" MinWidth="160" SelectionChanged="cbxFanSpeed_SelectionChanged">
                    <ComboBoxItem Content="Off"/>
                    <ComboBoxItem Content="25%"/>
                    <ComboBoxItem Content="50%"/>
                    <ComboBoxItem Content="75%"/>
                    <ComboBoxItem Content="90%"/>
                    <ComboBoxItem Content="95%"/>
                    <ComboBoxItem Content="100%"/>
                </ComboBox>
                <TextBlock Text="Select fan duty cycle. Higher = more airflow, more noise."
                    FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </ui:CardControl>

        <!-- RGB Control -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Color24" Margin="0,0,8,0"/>
                    <TextBlock Text="RGB Lighting"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cbxRgbMode" MinWidth="160" SelectionChanged="cbxRgbMode_SelectionChanged">
                        <ComboBoxItem Content="Off"/>
                        <ComboBoxItem Content="Static"/>
                        <ComboBoxItem Content="Breathe"/>
                        <ComboBoxItem Content="Colorful"/>
                        <ComboBoxItem Content="Breathe Color"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cbxRgbColor" MinWidth="160" SelectionChanged="cbxRgbColor_SelectionChanged">
                        <ComboBoxItem Content="Red"/>
                        <ComboBoxItem Content="Green"/>
                        <ComboBoxItem Content="Blue"/>
                        <ComboBoxItem Content="White"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </ui:CardControl>

        <!-- Settings -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Settings24" Margin="0,0,8,0"/>
                    <TextBlock Text="Settings"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <ui:ToggleSwitch x:Name="tsAutoConnect" Margin="0,0,9,0" Checked="tsAutoConnect_Checked" Unchecked="tsAutoConnect_Unchecked"/>
                <TextBlock Text="Auto-connect on startup" VerticalAlignment="Center"/>
            </StackPanel>
        </ui:CardControl>

    </StackPanel>
    </ScrollViewer>
</Page>
