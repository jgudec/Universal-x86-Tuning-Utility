<Page x:Class="Universal_x86_Tuning_Utility.Views.Pages.Games"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Universal_x86_Tuning_Utility.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      d:DataContext="{d:DesignInstance local:Games, IsDesignTimeCreatable=False}"
      d:Background="{DynamicResource ApplicationBackgroundBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d"
      d:DesignHeight="650"
      d:DesignWidth="900"
      Title="Games"
      Loaded="Page_Loaded"
      ScrollViewer.CanContentScroll="False"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Grid>
        <Grid Margin="18,10,18,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="26" FontWeight="Medium" Text="Game Library" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Launch tracked games and review their recorded performance data."
                           TextWrapping="Wrap" />
            </StackPanel>

            <ListBox x:Name="lbGames"
                     Grid.Row="1"
                     Margin="0,10,0,0"
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Stretch"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.PanningMode="VerticalOnly"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.Resources>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:Card x:Name="ccMain"
                                 Margin="0,0,0,8"
                                 Padding="14"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="64"
                                        Height="64"
                                        VerticalAlignment="Center"
                                        CornerRadius="8"
                                        ClipToBounds="True">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding iconPath}" Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,20,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="18"
                                               FontWeight="Medium"
                                               Text="{Binding gameName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding appType}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="{Binding path}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" MinWidth="100" Margin="0,0,18,0" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="Average FPS" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" Text="{Binding fpsData}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" MinWidth="118" Margin="0,0,18,0" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="Average Frametime" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" Text="{Binding msData}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button Width="44"
                                               Height="40"
                                               Margin="0,0,8,0"
                                               Appearance="Caution"
                                               Visibility="Collapsed"
                                               IsEnabled="False"
                                               ToolTip="Game configuration">
                                        <ui:SymbolIcon Symbol="Toolbox20" FontSize="22" />
                                    </ui:Button>
                                    <ui:Button Width="48"
                                               Height="40"
                                               Appearance="Primary"
                                               Tag="{Binding launchCommand}"
                                               ToolTip="Launch game"
                                               Click="Button_Click">
                                        <ui:SymbolIcon Symbol="Play20" FontSize="22" />
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="NoGamesPanel"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <ui:SymbolIcon Symbol="Games24" FontSize="42" HorizontalAlignment="Center" />
                <TextBlock Margin="0,12,0,0"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Text="No games found" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Text="Add a game manually or reload the library." />
            </StackPanel>

            <StackPanel x:Name="ActionsPanel"
                        Grid.Row="2"
                        Margin="0,4,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button x:Name="btnLoad"
                           Width="48"
                           Height="40"
                           Margin="0,0,8,0"
                           ToolTip="Reload the game library"
                           Click="btnLoad_Click">
                    <ui:SymbolIcon Symbol="ArrowSync20" FontSize="22" />
                </ui:Button>
                <ui:Button Width="48"
                           Height="40"
                           Appearance="Primary"
                           ToolTip="Add a game manually"
                           Click="addGameBtn_Click">
                    <ui:SymbolIcon Symbol="Add20" FontSize="22" />
                </ui:Button>
            </StackPanel>
        </Grid>

        <Grid Panel.ZIndex="10">
            <ui:Card x:Name="ccLoading"
                     Padding="56,34"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     HorizontalContentAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="22" FontWeight="Medium" HorizontalAlignment="Center" Text="Locating games" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="This should only take a few moments." />
                    <ui:LoadingScreen Margin="0,14,0,0"
                                      Background="Transparent"
                                      HorizontalAlignment="Center" />
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>
