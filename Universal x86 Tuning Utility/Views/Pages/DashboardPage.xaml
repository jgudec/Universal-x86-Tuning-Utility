<Page x:Class="Universal_x86_Tuning_Utility.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Universal_x86_Tuning_Utility.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dashboard"
      d:DataContext="{d:DesignInstance local:DashboardPage, IsDesignTimeCreatable=False}"
      d:DesignHeight="590"
      d:DesignWidth="1008"
      d:Background="{DynamicResource ApplicationBackgroundBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="164" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="256"
                CornerRadius="8,0,0,0"
                ClipToBounds="True">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/pexels-photo-8037008.jpeg"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Stretch="UniformToFill" />
            </Border.Background>

            <Grid>
                <Border CornerRadius="8,0,0,0">
                    <Border.Background>
                        <RadialGradientBrush Center="0.45,0.48"
                                             GradientOrigin="0.30,0.50"
                                             RadiusX="0.90"
                                             RadiusY="1.05">
                            <GradientStop Offset="0" Color="#1F000000" />
                            <GradientStop Offset="1" Color="#4F000000" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <Border Margin="64"
                        Padding="9"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   Foreground="#B7FFFFFF"
                                   Text="Welcome To" />

                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="Universal x86 Tuning Utility"
                                   TextWrapping="Wrap" />

                        <TextBlock FontSize="18"
                                   Foreground="#B7FFFFFF"
                                   Text="V26.3.0 Beta 1" />

                        <ui:Button x:Name="btnPremade"
                                   Height="36"
                                   Margin="0,12,0,0"
                                   Padding="30,6"
                                   HorizontalAlignment="Left"
                                   Appearance="Transparent"
                                   Command="{Binding ViewModel.NavigateCommand}"
                                   CommandParameter="premade"
                                   Content="Try Out The Premade Presets"
                                   Foreground="{DynamicResource TextFillColorLightPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <TextBlock Margin="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           FontSize="10"
                           Foreground="#57FFFFFF"
                           Text="Created and maintained by JamesCJ, with contributions from the wider community" />
            </Grid>
        </Border>
        <Grid Grid.Row="1"
              Margin="12,12,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:CardAction x:Name="caPremade"
                           Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,4,4"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="premade"
                           Icon="{ui:SymbolIcon Predictions20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Premade Presets" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="0"
                           Grid.Column="1"
                           Margin="4,0,4,4"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="custom"
                           Icon="{ui:SymbolIcon Book20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Custom Presets" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="0"
                           Grid.Column="2"
                           Margin="4,0,4,4"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="adaptive"
                           Icon="{ui:SymbolIcon Radar20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Adaptive Mode" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="0"
                           Grid.Column="3"
                           Margin="4,0,0,4"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="auto"
                           Icon="{ui:SymbolIcon Transmission20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Automations" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,4,4,0"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="games"
                           Icon="{ui:SymbolIcon Games20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Game Library" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="1"
                           Grid.Column="1"
                           Margin="4,4,4,0"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="info"
                           Icon="{ui:SymbolIcon Info20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="System Info" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="1"
                           Grid.Column="2"
                           Margin="4,4,4,0"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="help"
                           Icon="{ui:SymbolIcon ChatHelp20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Need Help?" />
            </ui:CardAction>

            <ui:CardAction Grid.Row="1"
                           Grid.Column="3"
                           Margin="4,4,0,0"
                           Command="{Binding ViewModel.NavigateCommand}"
                           CommandParameter="support"
                           Icon="{ui:SymbolIcon Money20}"
                           IsChevronVisible="True">
                <TextBlock FontSize="13"
                           FontWeight="Medium"
                           Text="Support Us" />
            </ui:CardAction>
        </Grid>
    </Grid>
</Page>
