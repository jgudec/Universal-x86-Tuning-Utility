                    <ui:CardExpander Name="sdWindowsProcessorPower"
                                     Margin="0,8,15,0"
                                     IsEnabled="True"
                                     IsExpanded="False"
                                     Icon="{ui:SymbolIcon Power20}">
                        <ui:CardExpander.Header>
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Medium" Text="Windows Processor Power" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Controls Windows processor boost, performance limits, core parking and energy preference." TextWrapping="Wrap" />
                            </StackPanel>
                        </ui:CardExpander.Header>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="200" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="13" FontWeight="DemiBold" Text="Processor Boost Mode" />
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Selects how Windows requests processor boost performance." TextWrapping="Wrap" />
