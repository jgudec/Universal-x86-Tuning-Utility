                                <ComboBox x:Name="cbxWindowsBoostMode" Grid.Column="1" Height="37" SelectedIndex="0">
                                    <ComboBoxItem>System Controlled</ComboBoxItem>
                                    <ComboBoxItem>Disabled</ComboBoxItem>
                                    <ComboBoxItem>Enabled</ComboBoxItem>
                                    <ComboBoxItem>Aggressive</ComboBoxItem>
                                    <ComboBoxItem>Efficient Enabled</ComboBoxItem>
                                    <ComboBoxItem>Efficient Aggressive</ComboBoxItem>
                                    <ComboBoxItem>Aggressive at Guaranteed Performance</ComboBoxItem>
                                    <ComboBoxItem>Efficient Aggressive at Guaranteed Performance</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <StackPanel Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="DemiBold" Text="Minimum Processor State (%)" />
                                    <ui:SymbolIcon Margin="6,0,0,-2" Symbol="Info20" ToolTip="Sets the minimum processor performance state as a percentage." />
                                </StackPanel>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="33" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="cbWindowsMinState" />
                                    <ui:NumberBox x:Name="nudWindowsMinState" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="1" MaxDecimalPlaces="0" Value="{Binding ElementName=sdWindowsMinState, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Slider x:Name="sdWindowsMinState" Grid.Column="2" Margin="12,0,0,0" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" TouchDown="SizeSlider_TouchDown" />
                                </Grid>
                            </StackPanel>
                            <StackPanel Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="DemiBold" Text="Maximum Processor State (%)" />
                                    <ui:SymbolIcon Margin="6,0,0,-2" Symbol="Info20" ToolTip="Limits the maximum processor performance state as a percentage." />
                                </StackPanel>
                                <Grid Margin="0,8,0,0">
