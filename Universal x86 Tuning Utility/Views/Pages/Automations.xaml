<Page x:Class="Universal_x86_Tuning_Utility.Views.Pages.Automations"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Universal_x86_Tuning_Utility.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      d:DataContext="{d:DesignInstance local:Automations, IsDesignTimeCreatable=False}"
      d:Background="{DynamicResource ApplicationBackgroundBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d"
      d:DesignHeight="650"
      d:DesignWidth="800"
      Title="Automations"
      Loaded="Page_Loaded"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True">

    <Page.Resources>
        <Style TargetType="{x:Type CheckBox}"
               BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Style.Triggers>
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Width" Value="20" />
                    <Setter Property="Height" Value="20" />
                    <Setter Property="MinWidth" Value="20" />
                    <Setter Property="MinHeight" Value="20" />
                    <Setter Property="Padding" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <StackPanel Margin="18,10,18,18">
        <TextBlock FontSize="26"
                   FontWeight="Medium"
                   Text="Automations" />
        <TextBlock Margin="0,4,0,12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Apply presets automatically when power or system state changes."
                   TextWrapping="Wrap" />

        <ui:CardControl Icon="{ui:SymbolIcon BatteryCharge20}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Medium" Text="Preset on Battery Charge" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Apply a preset whenever the battery begins charging."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox x:Name="cbxCharge"
                                  MinWidth="150"
                                  Height="37"
                                  SelectedIndex="0"
                                  SelectionChanged="cbxCharge_SelectionChanged">
                            <ComboBoxItem>None</ComboBoxItem>
                        </ComboBox>
                        <ui:Button x:Name="btnChargeLoad"
                                   Width="44"
                                   Height="37"
                                   Margin="8,0,0,0"
                                   ToolTip="Refresh the preset list"
                                   Click="btnChargeLoad_Click">
                            <ui:SymbolIcon Symbol="ArrowSync20" FontSize="20" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Margin="0,8,0,0" Icon="{ui:SymbolIcon Battery720}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Medium" Text="Preset on Battery Discharge" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Apply a preset whenever the system begins running from battery power."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox x:Name="cbxDischarge"
                                  MinWidth="150"
                                  Height="37"
                                  SelectedIndex="0"
                                  SelectionChanged="cbxDischarge_SelectionChanged">
                            <ComboBoxItem>None</ComboBoxItem>
                        </ComboBox>
                        <ui:Button x:Name="btnDischargeLoad"
                                   Width="44"
                                   Height="37"
                                   Margin="8,0,0,0"
                                   ToolTip="Refresh the preset list"
                                   Click="btnDischargeLoad_Click">
                            <ui:SymbolIcon Symbol="ArrowSync20" FontSize="20" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Margin="0,8,0,0" Icon="{ui:SymbolIcon Sleep20}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Medium" Text="Preset on System Resume" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Apply a preset after the system resumes from sleep or hibernation."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox x:Name="cbxResume"
                                  MinWidth="150"
                                  Height="37"
                                  SelectedIndex="0"
                                  SelectionChanged="cbxResume_SelectionChanged">
                            <ComboBoxItem>None</ComboBoxItem>
                        </ComboBox>
                        <ui:Button x:Name="btnResumeLoad"
                                   Width="44"
                                   Height="37"
                                   Margin="8,0,0,0"
                                   ToolTip="Refresh the preset list"
                                   Click="btnResume_Click">
                            <ui:SymbolIcon Symbol="ArrowSync20" FontSize="20" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl x:Name="ccAutoOcCpuUv"
                        Margin="0,8,0,0"
                        Icon="{ui:SymbolIcon TopSpeed20}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Medium" Text="AutoOC: Adaptive CPU Undervolt" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Dynamically optimises CPU voltage with built-in stability protection. Initial tuning may temporarily cause instability or crashes."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox x:Name="cbCPUUV"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Click="CheckBox_Click" />
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl x:Name="ccAutoOcIgpuUv"
                        Margin="0,8,0,0"
                        Icon="{ui:SymbolIcon TopSpeed20}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Medium" Text="AutoOC: Adaptive iGPU Undervolt" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="Dynamically optimises iGPU voltage with built-in stability protection. Initial tuning may temporarily cause instability or crashes."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox x:Name="cbiGPUUV"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Click="CheckBox_Click" />
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>
    </StackPanel>
</Page>
