<ui:UiWindow
    x:Class="Universal_x86_Tuning_Utility.Views.Windows.InstallpawnIo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Universal_x86_Tuning_Utility.Views.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="PawnIO Driver Required"
    Height="450"
    Width="800"
 d:Background="{DynamicResource ApplicationBackgroundBrush}"
 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
 ExtendsContentIntoTitleBar="True"
 WindowBackdropType="Mica"
 WindowCornerPreference="Round"
 WindowStartupLocation="CenterScreen"
    Topmost="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="12,0,12,6" Grid.Row="1">
            <TextBlock FontSize="24" FontWeight="Medium" DockPanel.Dock="Top">
                PawnIO Driver Required
            </TextBlock>

            <StackPanel
                Name="spButtons"
                Orientation="Horizontal"
                DockPanel.Dock="Bottom"
                Height="45"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,9,0,0">

                <Button
                    Name="ToggleButton"
                    Margin="0,0,32,0"
                    Width="190"
                    Height="38"
                    Click="btn1_Click">
                    Install Driver
                </Button>

                <Button
                    Name="CloseButton"
                    Width="190"
                    Height="38"
                    Click="btn2_Click">
                    Cancel
                </Button>
            </StackPanel>

            <DockPanel>
                <ProgressBar
                    Name="pbStatus"
                    DockPanel.Dock="Bottom"
                    Value="0"
                    Minimum="0"
                    Maximum="100"
                    Margin="0,12,3,0"
                    Visibility="Collapsed" />

                <TextBlock
                    Name="tbxInfo"
                    VerticalAlignment="Center"
                    FontSize="16"
                    TextWrapping="Wrap"
                    FontWeight="Medium">
                    <Run Text="This application requires the PawnIO driver to access supported low-level hardware features." />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="The driver installation will be handled by the official PawnIO installer. Administrator permission may be required." />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="PawnIO is provided 'as is' without warranty of any kind, either express or implied. Use at your own risk. The authors are not liable for any damages arising from the use of this software." />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="All rights reserved." />
                    <LineBreak />
                    <Run Text="This installer can be redistributed unmodified." />
                    <LineBreak />
                    <Run Text="Copyright © 2026 namazso &lt;admin@namazso.eu&gt;" />
                </TextBlock>
            </DockPanel>
        </DockPanel>

        <ui:TitleBar
            Title="PawnIO Driver Setup"
            Icon="pack://application:,,,/Assets/applicationIcon-256.png"
            UseSnapLayout="True"
            CanMaximize="False"
            ShowMaximize="False"
            ShowClose="False"
            ShowMinimize="False" />
    </Grid>
</ui:UiWindow>