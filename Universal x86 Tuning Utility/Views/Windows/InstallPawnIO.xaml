<ui:FluentWindow x:Class="Universal_x86_Tuning_Utility.Views.Windows.InstallpawnIo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="PawnIO Driver Required"
    Width="800"
    Height="470"
    MinWidth="700"
    MinHeight="430"
    d:Background="{DynamicResource ApplicationBackgroundBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Topmost="True"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="PawnIO Driver Setup"
                     Icon="pack://application:,,,/Assets/applicationIcon-256.png"
                     CanMaximize="False"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     ShowClose="False" />

        <ui:Card Grid.Row="1" Margin="18,12,18,18" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info20" FontSize="28" Margin="0,0,12,0" />
                    <TextBlock FontSize="23"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Text="PawnIO Driver Required" />
                </StackPanel>

                <TextBlock x:Name="tbxInfo"
                           Grid.Row="1"
                           Margin="0,16,0,0"
                           VerticalAlignment="Top"
                           FontSize="14"
                           TextWrapping="Wrap">
                    <Run Text="This application requires the PawnIO driver to access supported low-level hardware features." />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="The official PawnIO installer will handle installation. Administrator permission may be required." />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="PawnIO is provided 'as is' without warranty of any kind, either express or implied. Use it at your own risk. The authors are not liable for damages arising from its use." />
                    <LineBreak />
                    <LineBreak />
                    <Run Text="This installer may be redistributed unmodified. Copyright © 2026 namazso &lt;admin@namazso.eu&gt;." />
                </TextBlock>

                <ProgressBar x:Name="pbStatus"
                             Grid.Row="2"
                             Height="6"
                             Margin="0,14,0,0"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Visibility="Collapsed" />

                <StackPanel x:Name="spButtons"
                            Grid.Row="3"
                            Margin="0,18,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <ui:Button x:Name="CloseButton"
                               Width="130"
                               Height="38"
                               Click="btn2_Click"
                               Content="Cancel" />
                    <ui:Button x:Name="ToggleButton"
                               Width="160"
                               Height="38"
                               Margin="10,0,0,0"
                               Appearance="Primary"
                               Click="btn1_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowDownload20" Margin="0,0,8,0" />
                            <TextBlock Text="Install Driver" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
