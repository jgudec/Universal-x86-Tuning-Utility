<ui:UiWindow x:Class="Universal_x86_Tuning_Utility.Views.Windows.FlydigiCurveEditorWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:Universal_x86_Tuning_Utility.Views.Controls"
             Title="Edit Fan Curve"
             Width="600" Height="450"
             ResizeMode="CanResizeWithGrip"
             WindowStartupLocation="CenterOwner"
             ExtendsContentIntoTitleBar="True"
             WindowBackdropType="Mica"
             WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Edit Fan Curve"
                     ShowMinimize="True"
                     ShowMaximize="False"
                     ShowClose="True"/>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Adjust fan speed across the temperature range."
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,8"/>

            <!-- Curve Editor -->
            <controls:FlydigiFanCurveEditor x:Name="_editor" Grid.Row="1"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Save" Width="90" Click="btnSave_Click" Margin="0,0,8,0"/>
                <Button Content="Cancel" Width="90" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:UiWindow>
