<ui:FluentWindow x:Class="Universal_x86_Tuning_Utility.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Universal_x86_Tuning_Utility.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
    x:Name="mainWindow"
    Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
    Width="1080"
    Height="640"
    MinWidth="980"
    MinHeight="420"
    d:DataContext="{d:DesignInstance local:MainWindow, IsDesignTimeCreatable=True}"
    d:Background="{DynamicResource ApplicationBackgroundBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d"
    Loaded="mainWindow_Loaded"
    StateChanged="UiWindow_StateChanged"
    Closing="UiWindow_Closing">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#4F4F4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  The title bar contains window navigation elements and some Tray related extras.  -->
        <!--  You can put additional controls in the header, such as a search bar.  -->
        <ui:TitleBar
            x:Name="tbMain"
            Grid.Row="0"
            Title="Universal x86 Tuning Utility">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/applicationIcon-256.png" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="48,0,0,0">
                    <TextBlock x:Name="ModelNameText" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0" Text="UXTU"/>
                    <Border x:Name="CpuChip" Style="{StaticResource ChipStyle}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE950;" FontSize="12" FontWeight="Bold" Foreground="#D0D0D0" VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock x:Name="CpuChipText" FontSize="11" FontWeight="SemiBold" Foreground="#E0E0E0" Text="Detecting CPU..." Margin="0,0,-28,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="GpuChip" Style="{StaticResource ChipStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7F4;" FontSize="12" FontWeight="Bold" Foreground="#D0D0D0" VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock x:Name="GpuChipText" FontSize="11" FontWeight="SemiBold" Foreground="#E0E0E0" Text="Detecting GPU..."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Margin="0,0,6,0"
                               Padding="10,4"
                               Appearance="Transparent"
                               Command="{Binding ViewModel.NavigateCommand}"
                               CommandParameter="download"
                               Content="{Binding ViewModel.Downloads}"
                               Visibility="{Binding ViewModel.IsDownloads, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:Button Margin="0,0,6,0"
                               Padding="10,4"
                               Appearance="Transparent"
                               Command="{Binding ViewModel.NavigateCommand}"
                               CommandParameter="support"
                               Content="Buy us a beer! ♥" />
                    <ui:Button Padding="10,4"
                               Appearance="Transparent"
                               Command="{Binding ViewModel.NavigateCommand}"
                               CommandParameter="discord"
                               Content="Join our Discord!" Margin="0,0,8,0"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                   Grid.Row="1"
                   Margin="0,0,0,2"
                   FontSize="11"
                   PaneDisplayMode="LeftFluent"
                   IsPaneOpen="False"
                   IsPaneToggleVisible="False"
                   IsBackButtonVisible="Collapsed"
                   AlwaysShowHeader="False"
                   HeaderVisibility="Collapsed"
                   HorizontalContentAlignment="Stretch"
                   VerticalContentAlignment="Stretch"
                   MenuItemsSource="{Binding ViewModel.NavigationItems}"
                   FooterMenuItemsSource="{Binding ViewModel.NavigationFooter}">

            <ui:NavigationView.Resources>
                <DataTemplate x:Key="NavigationLabelTemplate">
                    <TextBlock Text="{Binding}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">

                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Margin"
                                Value="0" />

                                <Style.Triggers>
                                    <DataTrigger
                                Binding="{Binding IsActive,
                                          RelativeSource={RelativeSource AncestorType={x:Type ui:NavigationViewItem}}}"
                                Value="False">
                                        <Setter Property="Margin"
                                        Value="0,4,0,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
                <Style TargetType="{x:Type ui:NavigationViewItem}"
               BasedOn="{StaticResource NavigationViewItemDefaultStyle}">

                    <Setter Property="FontSize"
                    Value="10" />

                    <Setter Property="ContentTemplate"
                    Value="{StaticResource NavigationLabelTemplate}" />
                </Style>

                <Style TargetType="{x:Type ui:SymbolIcon}">
                    <Setter Property="FontSize"
                    Value="21" />

                    <Setter Property="Margin"
                    Value="0" />

                    <Setter Property="VerticalAlignment"
                    Value="Center" />

                    <Style.Triggers>
                        <DataTrigger
                    Binding="{Binding IsActive,
                              RelativeSource={RelativeSource AncestorType={x:Type ui:NavigationViewItem}}}"
                    Value="False">

                            <Setter Property="Margin"
                            Value="0,4,0,-4" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>

            </ui:NavigationView.Resources>
        </ui:NavigationView>

        <tray:NotifyIcon x:Name="niTray"
                         LeftClick="NotifyIcon_LeftClick"
                         FocusOnLeftClick="False"
                         Icon="pack://application:,,,/Assets/applicationIcon-256.png"
                         MenuOnRightClick="True"
                         TooltipText="Universal x86 Tuning Utility">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem x:Name="miClose"
                              Header="Close Application"
                              Tag="close"
                              Click="miClose_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
