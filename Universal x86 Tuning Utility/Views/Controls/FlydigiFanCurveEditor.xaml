<UserControl x:Class="Universal_x86_Tuning_Utility.Views.Controls.FlydigiFanCurveEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="LeftToRight">

    <Grid Margin="0,8,0,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Y-axis labels (RPM %) -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">100%</Label>
            <Label Grid.Row="2" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">80%</Label>
            <Label Grid.Row="4" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">60%</Label>
            <Label Grid.Row="6" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">40%</Label>
            <Label Grid.Row="8" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">20%</Label>
            <Label Grid.Row="10" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                   Content="Fan Speed"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Grid>

        <!-- Graph area -->
        <Border Grid.Row="0" Grid.Column="1" Height="200"
                BorderBrush="{DynamicResource TextFillColorDisabledBrush}"
                BorderThickness="1,0,0,1"/>

        <!-- Canvas for curve line and fill -->
        <Canvas x:Name="_canvas" Grid.Row="0" Grid.Column="1" Height="200"/>

        <!-- Vertical sliders overlay -->
        <Grid x:Name="_slidersGrid" Grid.Row="0" Grid.Column="1" Height="200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <!-- X-axis labels (Temperature °C) -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">0°</Label>
                <Label Grid.Column="1" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">10°</Label>
                <Label Grid.Column="2" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">20°</Label>
                <Label Grid.Column="3" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">30°</Label>
                <Label Grid.Column="4" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">40°</Label>
                <Label Grid.Column="5" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">50°</Label>
                <Label Grid.Column="6" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">60°</Label>
                <Label Grid.Column="7" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">70°</Label>
                <Label Grid.Column="8" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">80°</Label>
                <Label Grid.Column="9" HorizontalAlignment="Center" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">90°</Label>
                <Label Grid.Column="10" HorizontalAlignment="Right" VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">100°</Label>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
