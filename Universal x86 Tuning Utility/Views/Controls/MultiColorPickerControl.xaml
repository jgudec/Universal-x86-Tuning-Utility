<UserControl x:Class="Universal_x86_Tuning_Utility.Views.Controls.MultiColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel>
        <!-- Color chips row + add/remove buttons -->
        <Border Name="ChipRowBorder"
                Background="Transparent"
                Margin="0,0,0,4">
            <StackPanel Name="ColorChipsPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <!-- Color chips injected dynamically -->
            </StackPanel>
        </Border>

        <!-- Speed -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Name="cbxSpeed" MinWidth="120" SelectedIndex="1" SelectionChanged="OnSpeedChanged">
                <ComboBoxItem Content="Fast"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="Slow"/>
            </ComboBox>
        </StackPanel>

        <!-- Brightness -->
        <StackPanel Margin="0,0,0,4">
            <TextBlock Text="Brightness (%)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <wpfui:NumberBox Grid.Column="0" Name="nudBrightness"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding ElementName=sliderBrightness, Path=Value}"
                                   SmallChange="1" MaxDecimalPlaces="0"
                                   Margin="0,0,12,0"/>
                <Slider Grid.Column="1" Name="sliderBrightness"
                        Minimum="0" Maximum="100"
                        Value="{Binding ElementName=nudBrightness, Path=Value}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="OnBrightnessChanged"/>
            </Grid>
        </StackPanel>
    </StackPanel>
</UserControl>
