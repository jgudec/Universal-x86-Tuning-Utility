<Window x:Class="Universal_x86_Tuning_Utility.Views.Overlay.PerformanceOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UXTU Performance Overlay"
        Width="{Binding WindowWidth}"
        Height="{Binding WindowHeight}"
        MinWidth="320"
        MinHeight="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        SizeToContent="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{Binding OverlayFontFamily}"
        Foreground="{Binding PrimaryTextBrush}">

    <Window.Resources>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{Binding PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="{Binding PanelBorderThickness}" />
            <Setter Property="CornerRadius" Value="{Binding PanelCornerRadius}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="FontSize" Value="{Binding LabelFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="{Binding ValueFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GraphLegendText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding LegendFontSize}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

    </Window.Resources>

    <Grid Visibility="{Binding ContentVisibility}"
          Opacity="{Binding OverlayOpacity}"
          ClipToBounds="True">

        <Viewbox Stretch="Fill"
                 StretchDirection="Both"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">

            <Grid Width="{Binding DesignWidth}"
                  Height="{Binding DesignHeight}"
                  ClipToBounds="True">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="305" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="775" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="307" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="118" />
                </Grid.RowDefinitions>
<Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource PanelStyle}"
                        Padding="22,16,22,14"
                        Visibility="{Binding LeftPanelVisibility}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70" />
                            <RowDefinition Height="66" />
                            <RowDefinition Height="3" />
                            <RowDefinition Height="99" />
                            <RowDefinition Height="3" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
<Grid Grid.Row="0"
                              Visibility="{Binding FpsBlockVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding CurrentFps}"
                                       FontSize="{Binding FpsFontSize}"
                                       FontWeight="Light"
                                       Foreground="{Binding PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="{Binding FpsFontSize}" />

                            <TextBlock Grid.Column="1"
                                       Text="FPS"
                                       Margin="14,14,0,0"
                                       FontSize="{Binding FpsUnitFontSize}"
                                       FontWeight="Bold"
                                       Foreground="{Binding PrimaryTextBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
<Grid Grid.Row="1"
                              Visibility="{Binding LowFpsBlockVisibility}"
                              Margin="0,0,0,6">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="1% Low"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding OnePercentLowFps, StringFormat={}{0} FPS}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="0.1% Low"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding PointOnePercentLowFps, StringFormat={}{0} FPS}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{Binding SeparatorBrush}" />
<Grid Grid.Row="3"
                              Margin="0,8,0,8"
                              Visibility="{Binding FrameTimeStatsVisibility}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="26" />
                                <RowDefinition Height="26" />
                                <RowDefinition Height="26" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Frametime"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding FrameTimeMs, StringFormat={}{0:0.0} ms}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="1% ms"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding OnePercentFrameTimeMs, StringFormat={}{0:0.0} ms}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="0.1% ms"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding PointOnePercentFrameTimeMs, StringFormat={}{0:0.0} ms}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />
                        </Grid>

                        <Border Grid.Row="4"
                                Background="{Binding SeparatorBrush}" />
<Grid Grid.Row="5"
                              Visibility="{Binding ApiBlockVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="API"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding GraphicsApi}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />
                        </Grid>
                    </Grid>
                </Border>
<Border Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource PanelStyle}"
                        Padding="14,10,22,10"
                        Visibility="{Binding BatteryTileVisibility}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
<Grid Grid.Column="0"
                              Width="72"
                              Height="72"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center">

                            <Ellipse Width="72"
                                     Height="72"
                                     Stroke="{Binding BatteryRingBackgroundBrush}"
                                     StrokeThickness="6" />

                            <Path Data="{Binding BatteryRingGeometry}"
                                  Stroke="{Binding BatteryBrush}"
                                  StrokeThickness="6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent" />

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">

                                <TextBlock Text="{Binding BatteryPercentText}"
                                           Foreground="{Binding BatteryBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />

                                <Viewbox Width="18"
                                         Height="18"
                                         HorizontalAlignment="Center">

                                    <Path Data="{Binding BatteryStateIconGeometry}"
                                          Fill="{Binding BatteryBrush}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </StackPanel>
                        </Grid>
<Grid Grid.Column="1"
                              VerticalAlignment="Center"
                              Margin="18,0,0,0">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="86" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Status"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding BatteryStatusText}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Time"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding BatteryTimeRemainingText}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Power"
                                       Style="{StaticResource LabelText}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding BatteryPowerText}"
                                       Style="{StaticResource ValueText}"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right" />
                        </Grid>
                    </Grid>
                </Border>
<Grid Grid.Row="0"
                      Grid.Column="2">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="70" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="70" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="147" />
                    </Grid.RowDefinitions>
<Border Grid.Row="0"
                            Style="{StaticResource PanelStyle}"
                            Visibility="{Binding GpuRowVisibility}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="116" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{Binding GpuBrush}"
                                    CornerRadius="6,0,0,6" />

                            <TextBlock Grid.Column="1"
                                       Text="GPU"
                                       Foreground="{Binding GpuBrush}"
                                       FontSize="{Binding HardwareLabelFontSize}"
                                       FontWeight="Bold"
                                       Margin="34,0,0,0"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding GpuTemperature, StringFormat={}{0}°C}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="3"
                                       Text="{Binding GpuUsage, StringFormat={}{0}%}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="4"
                                       Text="{Binding GpuPowerWatts, StringFormat={}{0}W}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="5"
                                       Text="{Binding GpuClockMhz, StringFormat={}{0} MHz}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="6"
                                       Text="{Binding GpuMemoryText}"
                                       Style="{StaticResource ValueText}" />
<Border Grid.Column="8"
                                    Width="{Binding MemoryBarWidth}"
                                    Height="{Binding MemoryBarHeight}"
                                    Background="{Binding MemoryBarBackgroundBrush}"
                                    CornerRadius="{Binding MemoryBarCornerRadius}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    ClipToBounds="True"
                                    Visibility="{Binding GpuSparklineVisibility}">

                                <Grid ClipToBounds="True">
                                    <Border Width="{Binding GpuMemoryUsageBarWidth}"
                                            Height="{Binding MemoryBarHeight}"
                                            Background="{Binding GpuBrush}"
                                            CornerRadius="{Binding MemoryBarCornerRadius}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
<Border Grid.Row="2"
                            Style="{StaticResource PanelStyle}"
                            Visibility="{Binding CpuRowVisibility}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="116" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{Binding CpuBrush}"
                                    CornerRadius="6,0,0,6" />

                            <TextBlock Grid.Column="1"
                                       Text="CPU"
                                       Foreground="{Binding CpuBrush}"
                                       FontSize="{Binding HardwareLabelFontSize}"
                                       FontWeight="Bold"
                                       Margin="34,0,0,0"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding CpuTemperature, StringFormat={}{0}°C}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="3"
                                       Text="{Binding CpuUsage, StringFormat={}{0}%}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="4"
                                       Text="{Binding CpuPowerWatts, StringFormat={}{0} W}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="5"
                                       Text="{Binding CpuClockMhz, StringFormat={}{0} MHz}"
                                       Style="{StaticResource ValueText}" />

                            <TextBlock Grid.Column="6"
                                       Text="{Binding SystemMemoryText}"
                                       Style="{StaticResource ValueText}" />
<Border Grid.Column="8"
                                    Width="{Binding MemoryBarWidth}"
                                    Height="{Binding MemoryBarHeight}"
                                    Background="{Binding MemoryBarBackgroundBrush}"
                                    CornerRadius="{Binding MemoryBarCornerRadius}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    ClipToBounds="True"
                                    Visibility="{Binding CpuSparklineVisibility}">

                                <Grid ClipToBounds="True">
                                    <Border Width="{Binding SystemMemoryUsageBarWidth}"
                                            Height="{Binding MemoryBarHeight}"
                                            Background="{Binding CpuBrush}"
                                            CornerRadius="{Binding MemoryBarCornerRadius}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
<Grid Grid.Row="4"
                          Visibility="{Binding BottomGraphsVisibility}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
<Border Grid.Column="0"
                                Style="{StaticResource PanelStyle}"
                                Padding="18,12,14,10"
                                Visibility="{Binding FrameTimeGraphVisibility}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Frame Time (ms)"
                                           FontSize="{Binding GraphTitleFontSize}"
                                           FontWeight="Bold"
                                           Foreground="{Binding PrimaryTextBrush}" />

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="{Binding GraphColumnWidth}" />
                                        <ColumnDefinition Width="118" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          Height="{Binding GraphHeight}"
                                          VerticalAlignment="Center">

                                        <TextBlock Text="{Binding FrameTimeAxisMaxText}"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   FontSize="{Binding AxisFontSize}"
                                                   VerticalAlignment="Top" />

                                        <TextBlock Text="{Binding FrameTimeAxisMidText}"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   FontSize="{Binding AxisFontSize}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Text="{Binding FrameTimeAxisMinText}"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   FontSize="{Binding AxisFontSize}"
                                                   VerticalAlignment="Bottom" />
                                    </Grid>

                                    <Canvas Grid.Column="1"
                                            Width="{Binding GraphWidth}"
                                            Height="{Binding GraphHeight}"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center">

                                        <Line X1="0"
                                              X2="{Binding GraphWidth}"
                                              Y1="0"
                                              Y2="0"
                                              Stroke="{Binding GraphGridLineBrush}"
                                              StrokeThickness="{Binding GraphGridLineThickness}" />

                                        <Line X1="0"
                                              X2="{Binding GraphWidth}"
                                              Y1="{Binding GraphMidY}"
                                              Y2="{Binding GraphMidY}"
                                              Stroke="{Binding GraphGridLineBrush}"
                                              StrokeThickness="{Binding GraphGridLineThickness}" />

                                        <Line X1="0"
                                              X2="{Binding GraphWidth}"
                                              Y1="{Binding GraphHeight}"
                                              Y2="{Binding GraphHeight}"
                                              Stroke="{Binding GraphGridLineBrush}"
                                              StrokeThickness="{Binding GraphGridLineThickness}" />

                                        <Polyline Points="{Binding FrameTimePoints}"
                                                  Stroke="{Binding FrameTimeBrush}"
                                                  StrokeThickness="{Binding GraphStrokeThickness}"
                                                  StrokeLineJoin="Round"
                                                  Visibility="{Binding FrameTimeLineVisibility}" />

                                        <Polyline Points="{Binding OnePercentFrameTimePoints}"
                                                  Stroke="{Binding OnePercentBrush}"
                                                  StrokeThickness="{Binding GraphStrokeThickness}"
                                                  StrokeLineJoin="Round"
                                                  Visibility="{Binding OnePercentFrameTimeLineVisibility}" />

                                        <Polyline Points="{Binding PointOnePercentFrameTimePoints}"
                                                  Stroke="{Binding ZeroPointOnePercentBrush}"
                                                  StrokeThickness="{Binding GraphStrokeThickness}"
                                                  StrokeLineJoin="Round"
                                                  Visibility="{Binding ZeroPointOnePercentFrameTimeLineVisibility}" />
                                    </Canvas>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Margin="24,0,0,0">

                                        <TextBlock Text="─ Frametime"
                                                   Foreground="{Binding FrameTimeBrush}"
                                                   Style="{StaticResource GraphLegendText}" />

                                        <TextBlock Text="─ 1% ms"
                                                   Foreground="{Binding OnePercentBrush}"
                                                   Style="{StaticResource GraphLegendText}" />

                                        <TextBlock Text="─ 0.1% ms"
                                                   Foreground="{Binding ZeroPointOnePercentBrush}"
                                                   Style="{StaticResource GraphLegendText}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
<Border Grid.Column="2"
                                Style="{StaticResource PanelStyle}"
                                Padding="18,12,14,10"
                                Visibility="{Binding PowerGraphVisibility}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Power (W)"
                                           FontSize="{Binding GraphTitleFontSize}"
                                           FontWeight="Bold"
                                           Foreground="{Binding PrimaryTextBrush}" />

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="{Binding GraphColumnWidth}" />
                                        <ColumnDefinition Width="122" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          Height="{Binding GraphHeight}"
                                          VerticalAlignment="Center">

                                        <TextBlock Text="{Binding PowerAxisMaxText}"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   FontSize="{Binding AxisFontSize}"
                                                   VerticalAlignment="Top" />

                                        <TextBlock Text="{Binding PowerAxisMidText}"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   FontSize="{Binding AxisFontSize}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Text="{Binding PowerAxisMinText}"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   FontSize="{Binding AxisFontSize}"
                                                   VerticalAlignment="Bottom" />
                                    </Grid>

                                    <Canvas Grid.Column="1"
                                            Width="{Binding GraphWidth}"
                                            Height="{Binding GraphHeight}"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center">

                                        <Line X1="0"
                                              X2="{Binding GraphWidth}"
                                              Y1="0"
                                              Y2="0"
                                              Stroke="{Binding GraphGridLineBrush}"
                                              StrokeThickness="{Binding GraphGridLineThickness}" />

                                        <Line X1="0"
                                              X2="{Binding GraphWidth}"
                                              Y1="{Binding GraphMidY}"
                                              Y2="{Binding GraphMidY}"
                                              Stroke="{Binding GraphGridLineBrush}"
                                              StrokeThickness="{Binding GraphGridLineThickness}" />

                                        <Line X1="0"
                                              X2="{Binding GraphWidth}"
                                              Y1="{Binding GraphHeight}"
                                              Y2="{Binding GraphHeight}"
                                              Stroke="{Binding GraphGridLineBrush}"
                                              StrokeThickness="{Binding GraphGridLineThickness}" />

                                        <Polyline Points="{Binding GpuPowerPoints}"
                                                  Stroke="{Binding GpuBrush}"
                                                  StrokeThickness="{Binding GraphStrokeThickness}"
                                                  StrokeLineJoin="Round"
                                                  Visibility="{Binding GpuPowerLineVisibility}" />

                                        <Polyline Points="{Binding CpuPowerPoints}"
                                                  Stroke="{Binding CpuBrush}"
                                                  StrokeThickness="{Binding GraphStrokeThickness}"
                                                  StrokeLineJoin="Round"
                                                  Visibility="{Binding CpuPowerLineVisibility}" />
                                    </Canvas>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Margin="24,0,0,0">

                                        <TextBlock Text="─ GPU Power"
                                                   Foreground="{Binding GpuBrush}"
                                                   Style="{StaticResource GraphLegendText}" />

                                        <TextBlock Text="─ CPU Power"
                                                   Foreground="{Binding CpuBrush}"
                                                   Style="{StaticResource GraphLegendText}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
